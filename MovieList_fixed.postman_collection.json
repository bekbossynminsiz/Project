            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Interstellar\", \"description\": \"A science fiction movie about space and time.\", \"release_date\": \"2014-11-07\", \"poster_url\": \"https://example.com/interstellar.jpg\", \"genre\": 1}"
            },
            "url": {
              "raw": "{{base_url}}/api/movies/",
